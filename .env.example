# Coffer — environment variables
#
# Copy this file to .env and fill in your values.
# .env is gitignored and should be chmod 600.

# SimpleFIN Bridge (bank account sync)
# Obtain from https://beta-bridge.simplefin.org after linking your banks
SIMPLEFIN_ACCESS_URL=

# Zerion API (EVM wallet positions)
# Obtain from https://developers.zerion.io
ZERION_API_KEY=

# Alchemy API (on-chain transfer history)
# Obtain from https://www.alchemy.com
ALCHEMY_API_KEY=

# Coinbase Advanced Trade API
# Create an API key at https://www.coinbase.com/settings/api
COINBASE_KEY_NAME=
COINBASE_PRIVATE_KEY=

# Receipt extraction (optional, see docs/email.md)
# COFFER_OLLAMA_URL=http://localhost:11434/api/generate
# COFFER_RECEIPT_MODEL=nuextract:3.8b
#
# For the Anthropic extractor (parsers.email.extractor.backend = "anthropic"):
# ANTHROPIC_API_KEY=
#
# For the OpenAI extractor (parsers.email.extractor.backend = "openai"):
# OPENAI_API_KEY=
#
# For the IMAP fetcher (parsers.email.fetcher.backend = "imap"); the actual
# var names come from parsers.email.fetcher.username_env / password_env:
# IMAP_USERNAME=
# IMAP_PASSWORD=

# Optional overrides (defaults are usually fine)
# FINANCE_DB=db/finance.sqlite
# FINANCE_PARSER_CACHE=db/parser-cache.sqlite
# PORT=3001
