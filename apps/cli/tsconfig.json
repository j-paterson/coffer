{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["bun"],
    "lib": ["ES2022"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "../../packages/shared/**/*.ts"],
  "exclude": ["test/fixtures/syntax-error.ts"]
}
